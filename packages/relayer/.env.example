# Target Stellar network. Defaults to "testnet" when unset; unknown values
# (including the removed "local") refuse to boot. Mainnet ("public") arrives
# after the external audit.
NETWORK=testnet

# Funded relayer account secret (S...). On testnet, fund via friendbot — see README.
# ALWAYS REQUIRED: the relayer refuses to boot without it (there is no dev
# fallback — a randomly generated keypair is unfunded and cannot pay fees).
RELAYER_SECRET=

# HTTP port the server listens on. Railway injects PORT automatically.
PORT=3000

# Trusted reverse-proxy hops, counted from the RIGHT of X-Forwarded-For.
# 0 = trust nothing (direct connections). Behind Railway's single edge proxy, use 1.
TRUST_PROXY_HOPS=1

# Legacy alias for a single trusted proxy hop (TRUST_PROXY_HOPS takes precedence).
# TRUST_PROXY=true

# Credit gating: "1" requires a prepaid credit balance (+ proof-of-control
# challenge) before relaying/sponsoring; "0" disables it.
# DEFAULT when UNSET: ALWAYS ON — otherwise anyone could drain the hot wallet
# through unauthenticated /relay and /sponsor-claim/submit. Leave unset to get
# the safe default; set RELAYER_REQUIRE_CREDIT=0 only to deliberately disable
# gating (e.g. a throwaway testnet experiment).
# RELAYER_REQUIRE_CREDIT=0

# Path to the JSON credit ledger. With credit gating ON (the default),
# point this at a file on a mounted PERSISTENT VOLUME. Railway's default
# filesystem is ephemeral — a restart/redeploy wipes the ledger, losing credit
# balances/reservations AND the consumed-deposit record (so already-claimed
# deposits could be re-claimed). The relayer logs a loud startup warning when
# this is unset or left under the default ./data directory.
# NOTE: CREDIT_LEDGER_PATH below is the DEV FALLBACK, used only when
# DATABASE_URL is unset. For any real deploy set DATABASE_URL (Postgres) and
# REDIS_URL (Redis) instead — see the "Durable + multi-instance backends"
# block below.
CREDIT_LEDGER_PATH=./data/credit-ledger.json

# --- Durable + multi-instance backends (recommended for any real deploy) ---
#
# DATABASE_URL: when set, the credit ledger (balances, consumed-deposit
# idempotency, reservations) is backed by Postgres instead of the JSON file —
# it survives restarts and is shared across instances. Use a free-tier provider
# (Neon/Supabase); pass the POOLED connection string with sslmode=require. The
# schema auto-migrates on boot (or run `npm run migrate`). If this is set but
# the database is unreachable the relayer REFUSES to boot (it never silently
# forks the ledger back onto local disk). Unset = the JSON dev fallback above.
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require
#
# REDIS_URL: when set, challenge nonces and rate-limit buckets live in Redis so
# multiple instances share them (a nonce is single-use fleet-wide; one rate
# bucket per client across the fleet). Use a free-tier provider (Upstash) with a
# rediss:// URL. Set but unreachable => refuses to boot (auth is fail-closed).
# Unset = per-instance in-memory state (fine for a single instance).
# REDIS_URL=rediss://default:pass@host:6379
#
# Max Postgres pool connections (free tiers cap low; default 5).
# PGPOOL_MAX=5

# Max XLM the relayer will fund a single sponsored account creation with.
SPONSOR_MAX_XLM=5

# Max in-flight held reserves the relayer will sponsor for claim flows (default 10).
SPONSOR_CLAIM_MAX_HELD=10

# Max operations allowed in an inner tx submitted to /relay (default 5).
MAX_RELAY_OPS=5

# Ceiling (stroops) clamped onto the fetched base fee before fee-bumping (default 10000).
MAX_BASE_FEE=10000

# Absolute cap (XLM) on the built outer fee-bump fee the relayer will sign (default 0.1).
MAX_RELAY_FEE_XLM=0.1

# Max future window (seconds) an inner tx maxTime may be from now; absent/further is rejected (default 600).
MAX_RELAY_TIMEBOUNDS_SECONDS=600

# Allowed CORS origin(s). Defaults to "*" (any origin) — the relayer logs a
# startup warning; set this to your app origin(s) in production.
CORS_ORIGIN=*

# Set to any truthy value to enable verbose debug logging.
# DEBUG=1
