# Target Stellar network. Defaults to "testnet" when unset; unknown values
# (including the removed "local") refuse to boot. Mainnet ("public") arrives
# after the external audit.
NETWORK=testnet

# HTTP port the server listens on. Railway injects PORT automatically.
PORT=3100

# Horizon override (tests and private Horizons). When unset, the per-network
# table URL is used (testnet -> https://horizon-testnet.stellar.org).
# HORIZON_URL=

# Where ingestion starts on a FRESH store: "now" (newest tx), "genesis" (the
# beginning of the feed), or a decimal Horizon paging token. Ignored once a
# cursor has been persisted — the stored position always wins.
INGEST_START=now

# Poll interval between ingest ticks in milliseconds (default 3000). A cold
# catch-up pages through the backlog within a single tick regardless.
INGEST_INTERVAL_MS=3000

# Feed continuity check interval in milliseconds (default 600000 = 10 min).
# Each check compares the ingest cursor against Horizon's retention window:
# ledgers Horizon dropped before they were ingested are recorded as permanent
# gaps and degrade /health; a cursor impossibly far past the chain head flags
# a suspected testnet reset under a stale database. The check fails CLOSED:
# ingestion never starts before the first successful check, bounds from a
# wrong-network root document are discarded, and a hole/reset is acted on only
# after two consecutive observations. A persistently failing check surfaces as
# ingest.continuityStale and degrades /health.
# GAP_CHECK_INTERVAL_MS=600000

# DATABASE_URL: when set, announcements + the ingest cursor are backed by
# Postgres — durable across restarts and shared across instances. Use a
# free-tier provider (Neon/Supabase); pass the POOLED connection string with
# sslmode=require. The schema auto-migrates on boot (or run `npm run migrate`).
# If this is set but the database is unreachable the indexer REFUSES to boot
# (it never silently falls back to memory). Unset = in-memory store: all
# announcements are lost on restart and re-ingested from INGEST_START.
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Max Postgres pool connections (free tiers cap low; default 5).
# PGPOOL_MAX=5

# Allowed CORS origin(s). Defaults to "*" — the candidate feed is public data,
# so a permissive default is intended here (unlike the relayer).
CORS_ORIGIN=*

# Per-IP rate limits in requests/minute (token bucket; 429 + Retry-After
# reporting the real remaining wait). The /announcements default is generous
# because a cold client scan legitimately pages the whole feed in a burst
# (200 records/page) and gets no second chance mid-scan — the limiter is an
# anti-abuse backstop, not a capacity control.
# ANNOUNCEMENTS_RPM=600
# HEALTH_RPM=120

# Behind reverse proxies, set to the number of trusted proxy hops so the rate
# limiter keys clients by the rightmost non-forgeable X-Forwarded-For entry.
# Unset/0 = X-Forwarded-For ignored (direct connections keyed by socket IP).
# The legacy TRUST_PROXY=true means one trusted hop.
# SECURITY: when this is set, the origin port must be reachable ONLY through
# the proxy chain. A directly-reachable origin lets clients forge the entry
# this selects (non-IP values are rejected and fall back to the socket
# address, but a forged valid IP still picks its own bucket).
# TRUST_PROXY_HOPS=1

# Set to any truthy value to enable verbose debug logging.
# DEBUG=1
