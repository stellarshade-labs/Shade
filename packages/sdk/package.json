{
  "name": "@shade/sdk",
  "version": "0.1.0",
  "description": "Shade — high-level SDK for private payments on Stellar via stealth addresses (DKSAP)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "keywords": [
    "stellar",
    "stealth",
    "privacy",
    "dksap",
    "sdk"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@shade/crypto": "0.1.0",
    "@stellar/stellar-sdk": "^16.0.0",
    "@noble/hashes": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0"
}
